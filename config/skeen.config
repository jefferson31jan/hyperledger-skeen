# Configuração dos shards Skeen
# Formato: shard.<id>.host=<host>
#          shard.<id>.port=<porta>
#
# Este shard (definido por SKEEN_SHARD_ID na variável de ambiente)
# escuta na porta correspondente e conecta aos demais.

shard.ShardA.host=localhost
shard.ShardA.port=12000

shard.ShardB.host=localhost
shard.ShardB.port=12001
